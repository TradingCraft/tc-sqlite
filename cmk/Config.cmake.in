@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Threads)
find_dependency(tc-base CONFIG)
# dl (libdl) is recorded in the sqlite3 target's INTERFACE_LINK_LIBRARIES by
# CMake when the library is built, and is propagated to consumers automatically
# through the exported target file.  No need to set CMAKE_DL_LIBS here.

include("${CMAKE_CURRENT_LIST_DIR}/@TARGETS_EXPORT_NAME@.cmake")
check_required_components("@PROJECT_NAME@")

# Compatibility alias so consumers can use SQLite::SQLite3 (FindSQLite3 convention)
if(NOT TARGET SQLite::SQLite3 AND TARGET tc-sqlite::sqlite3)
    add_library(SQLite::SQLite3 ALIAS tc-sqlite::sqlite3)
endif()